{
  "manifest_version": 3,
  "name": "Instagram Filter",
  "version": "0.1.0",
  "description": "Aggressively de-junks instagram.com.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "96": "icons/96.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://instagram.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "js": ["src/content/main.ts"],
      "css": ["src/content/styles.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Instagram Filter"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "instagram-filter@cheris.local",
      "strict_min_version": "142.0",
      "update_url": "https://ruminate1.github.io/instagram-filter/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
